///|
let cargo_toml : String =
  #|[package]
  #|name = "sample-app"
  #|version = "0.3.0"
  #|edition = "2021"
  #|description = "A sample Rust application for SBOM testing"
  #|
  #|[dependencies]
  #|serde = { version = "1.0.195", features = ["derive"] }
  #|serde_json = "1.0.111"
  #|tokio = { version = "1.35.1", features = ["full"] }
  #|reqwest = { version = "0.11.23", features = ["json"] }
  #|anyhow = "1.0.79"
  #|log = "0.4.20"
  #|env_logger = { version = "0.10.1", optional = true }
  #|
  #|[dev-dependencies]
  #|pretty_assertions = "1.4.0"
  #|tempfile = "3.9.0"
  #|
  #|[build-dependencies]
  #|build-info-build = "0.0.35"

///|
let cargo_lock : String =
  #|# This file is automatically @generated by Cargo.
  #|# It is not intended for manual editing.
  #|version = 3
  #|
  #|[[package]]
  #|name = "anyhow"
  #|version = "1.0.79"
  #|source = "registry+https://github.com/rust-lang/crates.io-index"
  #|checksum = "080e9890a082662b09c1ad45f567faeeb47f22b5fb23895fbe1e651e718e25ca"
  #|
  #|[[package]]
  #|name = "build-info-build"
  #|version = "0.0.35"
  #|source = "registry+https://github.com/rust-lang/crates.io-index"
  #|checksum = "59b0c46de4c1f65c21dae2b90a5a35d81897be71e0852ab6d73ec6d2c2cbad38"
  #|
  #|[[package]]
  #|name = "env_logger"
  #|version = "0.10.1"
  #|source = "registry+https://github.com/rust-lang/crates.io-index"
  #|checksum = "95b3f3e67048839cb0d0781f445682a35113da7121f7c949db0e2be96a4fbece"
  #|
  #|[[package]]
  #|name = "log"
  #|version = "0.4.20"
  #|source = "registry+https://github.com/rust-lang/crates.io-index"
  #|checksum = "b5e6163cb8c49088c2c36f57875e58ccd8c87c7427f7fbd50ea6710b2f3f2e8f"
  #|
  #|[[package]]
  #|name = "pretty_assertions"
  #|version = "1.4.0"
  #|source = "registry+https://github.com/rust-lang/crates.io-index"
  #|checksum = "af7cee1a6c8a5b9208b3cb1061f10c0cb689087b3d8ce85fb9d2dd7a29b6ba66"
  #|
  #|[[package]]
  #|name = "reqwest"
  #|version = "0.11.23"
  #|source = "registry+https://github.com/rust-lang/crates.io-index"
  #|checksum = "37b1ae8d9ac08420c66222fb9096fc5de435c3c48542bc5336c51892cffafb41"
  #|
  #|[[package]]
  #|name = "sample-app"
  #|version = "0.3.0"
  #|
  #|[[package]]
  #|name = "serde"
  #|version = "1.0.195"
  #|source = "registry+https://github.com/rust-lang/crates.io-index"
  #|checksum = "63261df402c1e712e519d191bed1b2d03fb47bdadebedc9cf8b5e71feecf9c2f"
  #|
  #|[[package]]
  #|name = "serde_json"
  #|version = "1.0.111"
  #|source = "registry+https://github.com/rust-lang/crates.io-index"
  #|checksum = "176e46277c5f3f6daa8c1e282a35b08f5cf4e2f7cdf637dfe24d3c6e80ba8deb"
  #|
  #|[[package]]
  #|name = "tempfile"
  #|version = "3.9.0"
  #|source = "registry+https://github.com/rust-lang/crates.io-index"
  #|checksum = "01ce4141aa927a6d1bd34a041795abd0db1cccba5d5f24b009f694bdf3a1f3fa"
  #|
  #|[[package]]
  #|name = "tokio"
  #|version = "1.35.1"
  #|source = "registry+https://github.com/rust-lang/crates.io-index"
  #|checksum = "c89b4efa943be685f629b149f53829423f8f5531ea21249408e8e2f8671ec818"

///|
test "cargo: project name and version are parsed correctly" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  inspect(project.name, content="sample-app")
  inspect(project.version, content="0.3.0")
}

///|
test "cargo: project type is Cargo" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  inspect(project.project_type.to_string(), content="cargo")
}

///|
test "cargo: runtime dependencies are detected" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let all_pkgs = project.all_packages()
  let names : Array[String] = all_pkgs.map(fn(p) { p.name })
  inspect(names.contains("serde"), content="true")
  inspect(names.contains("serde_json"), content="true")
  inspect(names.contains("tokio"), content="true")
  inspect(names.contains("reqwest"), content="true")
  inspect(names.contains("anyhow"), content="true")
  inspect(names.contains("log"), content="true")
}

///|
test "cargo: dev dependencies are detected" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let all_pkgs = project.all_packages()
  let names : Array[String] = all_pkgs.map(fn(p) { p.name })
  inspect(names.contains("pretty_assertions"), content="true")
  inspect(names.contains("tempfile"), content="true")
}

///|
test "cargo: build dependencies are detected" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let all_pkgs = project.all_packages()
  let names : Array[String] = all_pkgs.map(fn(p) { p.name })
  inspect(names.contains("build-info-build"), content="true")
}

///|
test "cargo: resolved versions from Cargo.lock" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let all_pkgs = project.all_packages()
  let serde = all_pkgs.filter(fn(p) { p.name == "serde" })
  inspect(serde.length() > 0, content="true")
  inspect(serde[0].version(), content="1.0.195")
}

///|
test "cargo: checksums extracted from Cargo.lock" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let all_pkgs = project.all_packages()
  let anyhow = all_pkgs.filter(fn(p) { p.name == "anyhow" })
  inspect(anyhow.length() > 0, content="true")
  inspect(
    anyhow[0].checksum,
    content="Some(\"080e9890a082662b09c1ad45f567faeeb47f22b5fb23895fbe1e651e718e25ca\")",
  )
}

///|
test "cargo: PURL format is correct" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let all_pkgs = project.all_packages()
  let serde = all_pkgs.filter(fn(p) { p.name == "serde" })
  inspect(serde.length() > 0, content="true")
  inspect(serde[0].to_purl(), content="pkg:cargo/serde@1.0.195")
}

///|
test "cargo: optional dependency group" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let all_pkgs = project.all_packages()
  let env_logger = all_pkgs.filter(fn(p) { p.name == "env_logger" })
  inspect(env_logger.length() > 0, content="true")
  inspect(env_logger[0].group.to_string(), content="optional")
}

///|
test "cargo: dev dependency group" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let all_pkgs = project.all_packages()
  let tempfile = all_pkgs.filter(fn(p) { p.name == "tempfile" })
  inspect(tempfile.length() > 0, content="true")
  inspect(tempfile[0].group.to_string(), content="dev")
}

///|
test "cargo: SPDX export contains required top-level fields" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let sbom = project.to_sbom()
  let spdx = @spdx.to_spdx(sbom)
  inspect(spdx.contains("\"spdxVersion\": \"SPDX-2.3\""), content="true")
  inspect(spdx.contains("\"dataLicense\": \"CC0-1.0\""), content="true")
  inspect(spdx.contains("\"SPDXID\": \"SPDXRef-DOCUMENT\""), content="true")
  inspect(spdx.contains("\"packages\""), content="true")
  inspect(spdx.contains("\"relationships\""), content="true")
}

///|
test "cargo: SPDX export contains serde package entry" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let sbom = project.to_sbom()
  let spdx = @spdx.to_spdx(sbom)
  inspect(spdx.contains("\"serde\""), content="true")
  inspect(spdx.contains("\"1.0.195\""), content="true")
  inspect(spdx.contains("pkg:cargo/serde@1.0.195"), content="true")
}

///|
test "cargo: SPDX relationships use DEPENDS_ON" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let sbom = project.to_sbom()
  let spdx = @spdx.to_spdx(sbom)
  inspect(spdx.contains("\"DEPENDS_ON\""), content="true")
  inspect(spdx.contains("\"DESCRIBES\""), content="true")
}

///|
test "cargo: CycloneDX export contains required fields" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let sbom = project.to_sbom()
  let cdx = @cyclonedx.to_cyclonedx(sbom)
  inspect(cdx.contains("\"bomFormat\": \"CycloneDX\""), content="true")
  inspect(cdx.contains("\"specVersion\": \"1.5\""), content="true")
  inspect(cdx.contains("\"serialNumber\""), content="true")
  inspect(cdx.contains("\"components\""), content="true")
}

///|
test "cargo: CycloneDX export contains serde component" {
  let project = @cargo_pkg.parse_cargo_project(
    "sample-app",
    cargo_toml,
    Some(cargo_lock),
  )
  let sbom = project.to_sbom()
  let cdx = @cyclonedx.to_cyclonedx(sbom)
  inspect(cdx.contains("\"serde\""), content="true")
  inspect(cdx.contains("pkg:cargo/serde@1.0.195"), content="true")
}

///|
test "cargo: parsing without lock file still captures deps" {
  let project = @cargo_pkg.parse_cargo_project("sample-app", cargo_toml, None)
  let all_pkgs = project.all_packages()
  inspect(all_pkgs.length() > 0, content="true")
  let names : Array[String] = all_pkgs.map(fn(p) { p.name })
  inspect(names.contains("serde"), content="true")
  inspect(names.contains("tokio"), content="true")
}

///|
test "cargo: inline table dep captures version requirement" {
  let project = @cargo_pkg.parse_cargo_project("sample-app", cargo_toml, None)
  let all_pkgs = project.all_packages()
  let serde = all_pkgs.filter(fn(p) { p.name == "serde" })
  inspect(serde.length() > 0, content="true")
  inspect(serde[0].requirement is Some(_), content="true")
}
